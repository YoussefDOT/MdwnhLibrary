rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null
        && resource != null
        && isFolderMember(resource.data.folderId);
      allow update: if request.auth != null
        && resource != null
        && isFolderEditor(resource.data.folderId);
      allow read: if resource != null
        && isPublicFolderProject(uid, resource.data.folderId);
    }
    match /sharedProjects/{shareId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerUid;
      // Owner may change anything. A holder of an edit-link (mode == 'edit') may
      // update the project content but must NOT be able to take over the share
      // doc: ownerUid, mode, shareId and projectId are immutable for non-owners.
      allow update: if request.auth != null && (
                      request.auth.uid == resource.data.ownerUid
                      || (resource.data.mode == 'edit'
                          && request.resource.data.ownerUid == resource.data.ownerUid
                          && request.resource.data.mode == resource.data.mode
                          && request.resource.data.shareId == resource.data.shareId
                          && request.resource.data.projectId == resource.data.projectId)
                    );
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerUid;
    }
    match /userProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /folderShares/{folderId} {
      allow read: if (resource != null && resource.data.publicLinkEnabled == true)
        || (request.auth != null && (
          resource == null ||
          request.auth.uid == resource.data.ownerUid ||
          request.auth.uid in resource.data.memberUids
        ));
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerUid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.ownerUid;
    }
    match /userShares/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /sharedFolderLinks/{linkId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerUid;
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerUid;
    }
    match /pendingInvites/{email} {
      // Only the invitee may read their own pending invites (no existence oracle
      // for arbitrary email addresses).
      allow read: if request.auth != null && request.auth.token.email == email;
      // Writes stay open to authenticated users: the folder owner writes an
      // invite keyed by the invitee's email, and the invitee clears their own
      // on login. This grants no access on its own — folderShares membership is
      // owner-gated below, so a spoofed invite is never honoured.
      allow write: if request.auth != null;
    }
    match /projectChats/{chatId} {
      allow read: if false;
      // The parent doc records ownerUid/folderId that gate message reads, so it
      // must not be forgeable. Creators may only claim self-ownership or prove
      // membership of the folder they name; ownerUid/folderId are immutable.
      allow create: if request.auth != null
        && request.resource.data.ownerUid is string
        && (
          request.resource.data.ownerUid == request.auth.uid
          || (request.resource.data.folderId != null && isFolderMember(request.resource.data.folderId))
        );
      allow update: if request.auth != null
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.folderId == resource.data.folderId
        && (
          resource.data.ownerUid == request.auth.uid
          || (resource.data.folderId != null && isFolderMember(resource.data.folderId))
        );
    }
    match /projectChats/{chatId}/messages/{msgId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/projectChats/$(chatId))
        && (
          get(/databases/$(database)/documents/projectChats/$(chatId)).data.ownerUid == request.auth.uid ||
          isFolderMember(get(/databases/$(database)/documents/projectChats/$(chatId)).data.folderId)
        );
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && exists(/databases/$(database)/documents/projectChats/$(chatId))
        && (
          get(/databases/$(database)/documents/projectChats/$(chatId)).data.ownerUid == request.auth.uid ||
          isFolderMember(get(/databases/$(database)/documents/projectChats/$(chatId)).data.folderId)
        );
    }
    function isPublicFolderProject(ownerUid, folderId) {
      return folderId != null
        && exists(/databases/$(database)/documents/folderShares/$(folderId))
        && get(/databases/$(database)/documents/folderShares/$(folderId)).data.publicLinkEnabled == true
        && get(/databases/$(database)/documents/folderShares/$(folderId)).data.ownerUid == ownerUid;
    }
    function isFolderMember(folderId) {
      return folderId != null
        && exists(/databases/$(database)/documents/folderShares/$(folderId))
        && request.auth.uid in get(/databases/$(database)/documents/folderShares/$(folderId)).data.memberUids;
    }
    function isFolderEditor(folderId) {
      return folderId != null
        && exists(/databases/$(database)/documents/folderShares/$(folderId))
        && request.auth.uid in get(/databases/$(database)/documents/folderShares/$(folderId)).data.editorUids;
    }
  }
}
